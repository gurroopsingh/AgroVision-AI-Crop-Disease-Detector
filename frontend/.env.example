# Frontend Environment Variables

# The base URL of your deployed backend API (e.g. your Hugging Face Space URL)
# Keep it empty for local development (Vite will use the proxy defined in vite.config.js)
# For production (Vercel), set this in your Vercel Project Settings -> Environment Variables.
# Example: VITE_API_URL=https://your-username-agrovision-api.hf.space
VITE_API_URL=
